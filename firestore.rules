rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Qualquer pessoa pode ler os produtos (necessário para a loja)
    // Apenas administradores podem escrever (criar, editar, apagar)
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.admin == true;
    }
    
    // Apenas administradores podem ler e atualizar todos os pedidos
    // Um cliente autenticado pode criar um pedido e ler os seus próprios pedidos
    match /orders/{orderId} {
      allow read, update: if request.auth != null && get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.admin == true;
      allow create: if request.auth != null;
      allow get: if request.auth != null && (get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.admin == true || resource.data.userId == request.auth.uid);
      allow delete: if false;
    }

    // Um utilizador autenticado só pode ler a sua própria permissão
    match /roles/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // Ninguém pode alterar permissões diretamente
    }
    
    // Um utilizador pode criar uma conta e ler/atualizar os seus próprios dados
    match /users/{userId} {
       allow read, update: if request.auth != null && request.auth.uid == userId;
       allow create: if true;
    }
  }
}
