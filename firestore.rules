rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Coleção 'products':
    // - Leitura (get, list) é pública para que a loja possa mostrar os produtos.
    // - Escrita (create, update, delete) só é permitida se o usuário for um admin.
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.admin == true;
    }
    
    // Coleção 'roles':
    // - Permite que um usuário autenticado leia sua própria permissão.
    // - Ninguém pode escrever diretamente nesta coleção (é gerenciada pelo criar-admin.js).
    match /roles/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }
    
    // Coleção 'orders':
    // - Leitura (get, list) e Escrita (create, update) só são permitidas para administradores.
    // - Um cliente também pode ler seu próprio pedido.
    match /orders/{orderId} {
      allow read: if (request.auth != null && get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.admin == true)
                      || (request.auth != null && resource.data.userId == request.auth.uid);
      allow create: if request.auth != null; // Qualquer usuário logado pode criar um pedido
      allow update: if request.auth != null && get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.admin == true;
      allow delete: if false; // Ninguém pode apagar pedidos
    }
    
    // Coleção 'users':
    // - Um usuário pode ler e atualizar seus próprios dados.
    // - Ninguém pode ler os dados de outro usuário, exceto admins.
    match /users/{userId} {
       allow read, update: if request.auth != null && request.auth.uid == userId;
       allow create: if true; // Permite o registo
    }
  }
}
